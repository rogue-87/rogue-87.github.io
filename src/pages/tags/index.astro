---
import Layout from "../../layouts/Layout.astro";
import "../../style/tags.scss";

const allPosts = await Astro.glob("../posts/blogs/*.md");
const tags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];
const title = "Tag Index";
---

<Layout title={title}>
  <h1>Tags</h1>
  <main>
    <div class="tags">
      {
        tags.map((tag) => (
          <p class="tag">
            <a href={`/den/tags/${tag}`}>{tag}</a>
          </p>
        ))
      }
    </div>
  </main>
</Layout>
